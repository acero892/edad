<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
</head>
<body>
    <pre id="json-response">Cargando API...</pre>

    <script>
        const urlParams = new URLSearchParams(window.location.search);
        const fechaNacimiento = urlParams.get('fecha');
        let respuesta = {};

        if (fechaNacimiento) {
            const fechaNac = new Date(fechaNacimiento + "T00:00:00"); // Forzamos formato local
            const hoy = new Date();
            
            if (isNaN(fechaNac.getTime())) {
                respuesta = { "error": "Formato inválido. Usa YYYY-MM-DD" };
            } else {
                let edad = hoy.getFullYear() - fechaNac.getFullYear();
                const m = hoy.getMonth() - fechaNac.getMonth();
                if (m < 0 || (m === 0 && hoy.getDate() < fechaNac.getDate())) {
                    edad--;
                }
                respuesta = { "fecha_nacimiento": fechaNacimiento, "edad": edad };
            }
        } else {
            respuesta = { "instrucciones": "Agrega ?fecha=YYYY-MM-DD al final de la URL" };
        }

        document.getElementById('json-response').textContent = JSON.stringify(respuesta, null, 2);
    </script>
</body>
</html>
